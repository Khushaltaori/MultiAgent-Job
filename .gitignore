# =============================================================================
# AI Job Coach – Root .gitignore
# =============================================================================

# ── Secrets & Environment Variables ──────────────────────────────────────────
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# ── Python Caches & Compiled Files ───────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Virtual Environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
**/.venv/
**/venv/

# ── Python Packaging & Distribution ──────────────────────────────────────────
*.egg-info/
dist/
build/
*.egg
.eggs/
MANIFEST

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Type Checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.pyright/
.ruff_cache/

# ── IDE & Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS Files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Node.js / Next.js (frontend) ──────────────────────────────────────────────
node_modules/
.next/
.nuxt/
out/
*.tsbuildinfo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Uploads / Generated Files ─────────────────────────────────────────────────
uploads/
*.pdf
*.docx
