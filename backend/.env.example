# ─────────────────────────────────────────────────────────────────────────────
# AI Job Coach – Environment Variables
# Copy this file to .env and fill in real values before running the server.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=ai_job_coach

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_strong_random_secret_key
ALGORITHM=HS256

# ── Token lifetimes ───────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production example: https://www.myjobcoach.app
FRONTEND_ORIGIN=http://localhost:3000

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_KEY
OPENAI_MODEL=gpt-4o-mini

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Format: "<count>/<period>"  e.g. "10/minute", "100/hour"
RATE_LIMIT_AUTH=10/minute

# ── Environment ───────────────────────────────────────────────────────────────
# "development" → refresh cookie secure=False (allows http://localhost)
# "production"  → refresh cookie secure=True  (requires HTTPS)
ENVIRONMENT=development
